# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=replace-with-a-long-random-value

# Choose "local" for fully self-hosted accounts or "firebase" for Firebase Authentication.
# Existing installations which omit this setting continue to use Firebase.
AUTH_PROVIDER=local

# Comma-separated browser origins allowed to use local auth. Do not include trailing slashes.
AUTH_ALLOWED_ORIGINS=https://index.example.com,http://192.168.1.10:5050
AUTH_COOKIE_SECURE=true
AUTH_SESSION_DAYS=30
AUTH_IDLE_DAYS=7

# One-time first-run web setup token. Generate with: openssl rand -hex 32
# Remove this from .env after the first owner has been created.
LOCAL_SETUP_TOKEN=

# Firebase web application configuration (public client settings)
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=

# Comma-separated Firebase accounts permitted to use the inbox
ALLOWED_EMAILS=
REQUIRE_VERIFIED_EMAIL=true

# Host storage paths used by Docker Compose
INDEX_DATA_PATH=/path/to/persistent/index-inbox-data
FIREBASE_CREDENTIALS_PATH=

# Optional automation endpoint invoked from the Storage & Export panel
BACKUP_HOOK_URL=
